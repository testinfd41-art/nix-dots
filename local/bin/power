#!/usr/bin/env bash

options="Shutdown
Reboot
Lock
Suspend
Logout"

chosen=$(echo -e "$options" | fuzzel --dmenu --prompt="Power: ")

lock_and_suspend() {
    swaylock -f
    systemctl suspend
}

case "$chosen" in
Shutdown)
    systemctl poweroff
    ;;
Reboot)
    systemctl reboot
    ;;
Lock)
    swaylock -f
    ;;
Suspend)
    lock_and_suspend
    ;;
Logout)
    niri msg action quit --skip-confirmation
    ;;
esac
